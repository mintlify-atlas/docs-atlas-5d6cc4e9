  "keyFeatures": [
    "Precise appearance and voice cloning using AI algorithms",
    "Text and voice-driven virtual avatar animation",
    "Fully offline operation for privacy protection",
    "Efficient video synthesis with lip-sync synchronization",
    "Multi-language support (8 languages)",
    "Docker-based deployment with GPU acceleration",
    "Open APIs for model training and video generation",
    "Cross-platform support (Windows, Linux)"
  ],
  "publicApiSurface": [
    "POST /v1/preprocess - Model training and voice preprocessing",
    "POST /v1/invoke - Audio synthesis with cloned voice",
    "POST /easy/submit - Video synthesis job submission",
    "GET /easy/query - Video synthesis progress query",
    "IPC: model/addModel - Add new avatar model",
    "IPC: model/page - List avatar models",
    "IPC: video/make - Generate video from model",
    "IPC: video/save - Save video project",
    "IPC: voice/audition - Preview voice synthesis"
  ]
